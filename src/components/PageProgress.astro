---
---
<div id="tp-widget" aria-live="polite">
  <div id="tp-tasks-row">
    <span id="tp-tasks-count"></span>
    <div class="tp-bar-track">
      <div id="tp-tasks-fill" class="tp-bar-fill"></div>
    </div>
  </div>
  <div id="tp-written-row">
    <span id="tp-written-count"></span>
    <div class="tp-bar-track">
      <div id="tp-written-fill" class="tp-bar-fill tp-bar-written"></div>
    </div>
  </div>
</div>

<style is:global>
  #tp-widget {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    background: var(--sl-color-bg, white);
    border: 1.5px solid var(--sl-color-hairline, #e5e7eb);
    border-radius: 0.6rem;
    padding: 0.5rem 0.85rem;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.12);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--sl-color-text, #374151);
    display: none;
    flex-direction: column;
    gap: 0.4rem;
    min-width: 155px;
    z-index: 200;
  }
  #tp-tasks-row, #tp-written-row {
    display: none;
    flex-direction: column;
    gap: 0.25rem;
  }
  .tp-bar-track {
    height: 4px;
    background: var(--sl-color-gray-6, #e5e7eb);
    border-radius: 999px;
    overflow: hidden;
  }
  .tp-bar-fill {
    height: 100%;
    background: #ea580c;
    border-radius: 999px;
    width: 0%;
    transition: width 0.3s ease, background 0.3s;
  }
  .tp-bar-fill.done {
    background: #16a34a;
  }
  .tp-bar-written {
    background: #0d9488;
  }
  .tp-bar-written.done {
    background: #16a34a;
  }

  /* Badge ✓ dans la sidebar */
  .tp-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 15px;
    height: 15px;
    background: #16a34a;
    color: white;
    border-radius: 999px;
    font-size: 9px;
    font-weight: 800;
    margin-left: 0.4rem;
    vertical-align: middle;
    line-height: 1;
    flex-shrink: 0;
  }
</style>

<script>
  function updateProgress() {
    const widget = document.getElementById('tp-widget');
    const tasksRow = document.getElementById('tp-tasks-row');
    const writtenRow = document.getElementById('tp-written-row');
    if (!widget || !tasksRow || !writtenRow) return;

    const tasksTotal = document.querySelectorAll('.task-block').length;
    const tasksDone = document.querySelectorAll('.task-block.task-done').length;
    const writtenTotal = document.querySelectorAll('.written-block').length;
    const writtenDone = document.querySelectorAll('.written-block.written-done').length;

    if (tasksTotal === 0 && writtenTotal === 0) {
      widget.style.display = 'none';
      return;
    }

    widget.style.display = 'flex';

    if (tasksTotal > 0) {
      tasksRow.style.display = 'flex';
      const count = document.getElementById('tp-tasks-count');
      const fill = document.getElementById('tp-tasks-fill');
      if (count) count.textContent = `🟠 ${tasksDone} / ${tasksTotal} tâche${tasksTotal > 1 ? 's' : ''}`;
      if (fill) {
        fill.style.width = `${Math.round((tasksDone / tasksTotal) * 100)}%`;
        fill.classList.toggle('done', tasksDone === tasksTotal);
      }
    } else {
      tasksRow.style.display = 'none';
    }

    if (writtenTotal > 0) {
      writtenRow.style.display = 'flex';
      const count = document.getElementById('tp-written-count');
      const fill = document.getElementById('tp-written-fill');
      if (count) count.textContent = `✏ ${writtenDone} / ${writtenTotal} livrable${writtenTotal > 1 ? 's' : ''}`;
      if (fill) {
        fill.style.width = `${Math.round((writtenDone / writtenTotal) * 100)}%`;
        fill.classList.toggle('done', writtenDone === writtenTotal);
      }
    } else {
      writtenRow.style.display = 'none';
    }
  }

  function updateSidebar() {
    document.querySelectorAll<HTMLAnchorElement>('nav a[href]').forEach(link => {
      if (link.getAttribute('href')?.startsWith('#')) return;
      try {
        const pathname = new URL(link.href).pathname;
        const tasksTotal = parseInt(localStorage.getItem(`tp-tasks-total:${pathname}`) ?? '0', 10);
        const writtenTotal = parseInt(localStorage.getItem(`tp-written-total:${pathname}`) ?? '0', 10);
        const total = tasksTotal + writtenTotal;
        if (total === 0) return;

        let done = 0;
        for (let i = 0; i < localStorage.length; i++) {
          const key = localStorage.key(i);
          if (key?.startsWith(`tp:${pathname}:`) || key?.startsWith(`tp-w:${pathname}:`)) done++;
        }

        const existing = link.querySelector('.tp-badge');
        if (done === total) {
          if (!existing) {
            const badge = document.createElement('span');
            badge.className = 'tp-badge';
            badge.textContent = '✓';
            badge.setAttribute('aria-label', 'Complété');
            link.appendChild(badge);
          }
        } else {
          existing?.remove();
        }
      } catch { /* URL cross-origin ou malformée */ }
    });
  }

  function update() {
    updateProgress();
    updateSidebar();
  }

  update();
  document.addEventListener('astro:page-load', update);
  window.addEventListener('task-changed', update);
</script>
