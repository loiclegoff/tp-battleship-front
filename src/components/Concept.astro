---
interface Props {
  badge: string;
  chapter?: string;
  href: string;
}
const { badge, chapter, href } = Astro.props;
const linkLabel = chapter ? `Chapitre ${chapter}` : 'Documentation';
const isExternal = href.startsWith('http');
---
<div class="concept-block not-content">
  <div class="concept-header">
    <span class="concept-badge">{badge}</span>
    <a
      class="concept-link"
      href={href}
      target={isExternal ? '_blank' : undefined}
      rel={isExternal ? 'noopener noreferrer' : undefined}
    >{linkLabel} →</a>
  </div>
  <div class="concept-content sl-markdown-content">
    <slot />
  </div>
</div>

<style>
  .concept-block {
    border: 1px solid #c7d2fe;
    border-left: 4px solid #4f46e5;
    border-radius: 0.4rem;
    margin: 0.75rem 0;
    overflow: hidden;
    background: #fafaff;
  }

  .concept-header {
    background: #eef2ff;
    border-bottom: 1px solid #e0e7ff;
    padding: 0.45rem 0.9rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
  }

  .concept-badge {
    font-weight: 700;
    font-size: 0.85rem;
    color: #3730a3;
    letter-spacing: 0.01em;
  }

  .concept-link {
    font-size: 0.78rem;
    font-weight: 600;
    color: #4f46e5;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .concept-link:hover {
    color: #3730a3;
    text-decoration: underline;
  }

  .concept-content {
    padding: 0.6rem 0.95rem;
    font-size: 0.92rem;
    line-height: 1.5;
  }
  .concept-content :global(p:first-child) { margin-top: 0; }
  .concept-content :global(p:last-child) { margin-bottom: 0; }
  .concept-content :global(code) {
    font-size: 0.85em;
  }
</style>
