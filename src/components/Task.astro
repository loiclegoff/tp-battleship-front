---
interface Props {
  title?: string;
}
const { title = 'Tâche' } = Astro.props;
---
<div class="task-block not-content">
  <label class="task-header" title="Marquer comme complété">
    <input type="checkbox" class="task-checkbox" data-task-title={title} />
    <span class="task-checkmark" aria-hidden="true"></span>
    <span class="task-title">▶ {title}</span>
  </label>
  <div class="task-content sl-markdown-content">
    <slot />
  </div>
</div>

<script>
  function initTasks() {
    document.querySelectorAll<HTMLElement>('.task-block:not([data-ready])').forEach((block) => {
      block.setAttribute('data-ready', '');
      const checkbox = block.querySelector<HTMLInputElement>('.task-checkbox');
      if (!checkbox) return;

      const key = `tp:${location.pathname}:${checkbox.dataset.taskTitle ?? ''}`;

      if (localStorage.getItem(key) === '1') {
        checkbox.checked = true;
        block.classList.add('task-done');
      }

      checkbox.addEventListener('change', () => {
        if (checkbox.checked) {
          localStorage.setItem(key, '1');
          block.classList.add('task-done');
        } else {
          localStorage.removeItem(key);
          block.classList.remove('task-done');
        }
        window.dispatchEvent(new Event('task-changed'));
      });
    });

    // Mémorise le total de tâches de la page pour les badges sidebar
    const total = document.querySelectorAll('.task-block').length;
    if (total > 0) localStorage.setItem(`tp-total:${location.pathname}`, String(total));

    window.dispatchEvent(new Event('task-changed'));
  }

  initTasks();
  document.addEventListener('astro:page-load', initTasks);
</script>

<style>
  .task-block {
    border: 2px solid #ea580c;
    border-radius: 0.5rem;
    margin: 1.5rem 0;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .task-block.task-done {
    border-color: #16a34a;
  }

  .task-header {
    background: #fff7ed;
    border-bottom: 1px solid #fed7aa;
    padding: 0.6rem 1rem;
    font-weight: 700;
    font-size: 0.875rem;
    color: #c2410c;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    transition: background 0.2s, color 0.2s;
    cursor: pointer;
    user-select: none;
  }
  .task-block.task-done .task-header {
    background: #f0fdf4;
    border-bottom-color: #bbf7d0;
    color: #166534;
  }
  .task-checkbox {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }
  .task-checkmark {
    width: 17px;
    height: 17px;
    border: 2px solid #d97706;
    border-radius: 3px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: white;
    flex-shrink: 0;
    transition: background 0.2s, border-color 0.2s;
  }
  .task-block.task-done .task-checkmark {
    background: #16a34a;
    border-color: #16a34a;
  }
  .task-block.task-done .task-checkmark::after {
    content: '✓';
    color: white;
    font-size: 11px;
    font-weight: bold;
    line-height: 1;
  }

  .task-content {
    padding: 0.75rem 1.25rem;
  }
  .task-content :global(p:first-child) { margin-top: 0; }
  .task-content :global(p:last-child) { margin-bottom: 0; }
</style>
