---
interface Props {
  title?: string;
}
const { title = 'Exemple' } = Astro.props;
---
<div class="example-block not-content">
  <div class="example-header">
    <span class="example-icon" aria-hidden="true">◈</span>
    <span class="example-title">{title}</span>
  </div>
  <div class="example-content sl-markdown-content">
    <slot />
  </div>
</div>

<style>
  .example-block {
    border: 2px solid #6366f1;
    border-radius: 0.5rem;
    margin: 1.5rem 0;
    overflow: hidden;
  }

  .example-header {
    background: #eef2ff;
    border-bottom: 1px solid #c7d2fe;
    padding: 0.6rem 1rem;
    font-weight: 700;
    font-size: 0.875rem;
    color: #4338ca;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .example-icon {
    font-size: 1rem;
    line-height: 1;
  }

  .example-content {
    padding: 0.75rem 1.25rem;
  }
  .example-content :global(p:first-child) { margin-top: 0; }
  .example-content :global(p:last-child) { margin-bottom: 0; }
</style>
