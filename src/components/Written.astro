---
interface Props {
  title?: string;
}
const { title = 'Livrable écrit' } = Astro.props;
---
<div class="written-block not-content">
  <label class="written-header" title="Marquer comme complété">
    <input type="checkbox" class="written-checkbox" data-task-title={title} />
    <span class="written-checkmark" aria-hidden="true"></span>
    <span class="written-title">✏ {title}</span>
  </label>
  <div class="written-content sl-markdown-content">
    <slot />
  </div>
</div>

<script>
  function initWritten() {
    document.querySelectorAll<HTMLElement>('.written-block:not([data-ready])').forEach((block) => {
      block.setAttribute('data-ready', '');
      const checkbox = block.querySelector<HTMLInputElement>('.written-checkbox');
      if (!checkbox) return;

      const key = `tp-w:${location.pathname}:${checkbox.dataset.taskTitle ?? ''}`;

      if (localStorage.getItem(key) === '1') {
        checkbox.checked = true;
        block.classList.add('written-done');
      }

      checkbox.addEventListener('change', () => {
        if (checkbox.checked) {
          localStorage.setItem(key, '1');
          block.classList.add('written-done');
        } else {
          localStorage.removeItem(key);
          block.classList.remove('written-done');
        }
        window.dispatchEvent(new Event('task-changed'));
      });
    });

    const total = document.querySelectorAll('.written-block').length;
    if (total > 0) localStorage.setItem(`tp-written-total:${location.pathname}`, String(total));

    window.dispatchEvent(new Event('task-changed'));
  }

  initWritten();
  document.addEventListener('astro:page-load', initWritten);
</script>

<style>
  .written-block {
    border: 2px solid #0d9488;
    border-radius: 0.5rem;
    margin: 1.5rem 0;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .written-block.written-done {
    border-color: #16a34a;
  }

  .written-header {
    background: #f0fdfa;
    border-bottom: 1px solid #99f6e4;
    padding: 0.6rem 1rem;
    font-weight: 700;
    font-size: 0.875rem;
    color: #0f766e;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    transition: background 0.2s, color 0.2s;
    cursor: pointer;
    user-select: none;
  }
  .written-block.written-done .written-header {
    background: #f0fdf4;
    border-bottom-color: #bbf7d0;
    color: #166534;
  }

  .written-checkbox {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }
  .written-checkmark {
    width: 17px;
    height: 17px;
    border: 2px solid #0d9488;
    border-radius: 3px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: white;
    flex-shrink: 0;
    transition: background 0.2s, border-color 0.2s;
  }
  .written-block.written-done .written-checkmark {
    background: #16a34a;
    border-color: #16a34a;
  }
  .written-block.written-done .written-checkmark::after {
    content: '✓';
    color: white;
    font-size: 11px;
    font-weight: bold;
    line-height: 1;
  }

  .written-content {
    padding: 0.75rem 1.25rem;
  }
  .written-content :global(p:first-child) { margin-top: 0; }
  .written-content :global(p:last-child) { margin-bottom: 0; }
</style>
